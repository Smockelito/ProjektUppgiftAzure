@page
@model NwClient.Pages.Inspiration.IndexModel
@{
    ViewData["Title"] = "Träningsinspiration";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0"><i class="bi bi-stars"></i> Träningsinspiration</h1>
    <a asp-page="Random" class="btn btn-primary"><i class="bi bi-shuffle"></i> Slumpa övningar</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label fw-semibold">Filtrera pĺ svĺrighetsgrad</label>
                <select name="filterDifficultyId" class="form-select" onchange="this.form.submit()">
                    <option value="">— Alla svĺrighetsgrader —</option>
                    @foreach (var d in Model.Difficulties)
                    {
                        <option value="@d.Id" selected="@(Model.FilterDifficultyId == d.Id)">@d.CategoryName</option>
                    }
                </select>
            </div>
            @if (Model.FilterDifficultyId.HasValue)
            {
                <div class="col-auto">
                    <a asp-page="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i> Rensa filter
                    </a>
                </div>
            }
        </form>
    </div>
</div>

@if (!Model.Sessions.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Inga övningar hittades för det valda filtret.
    </div>
}
else
{
    <p class="text-muted mb-3">Visar @Model.Sessions.Count övning@(Model.Sessions.Count != 1 ? "ar" : "")</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var session in Model.Sessions)
        {
            <div class="col">
                <div class="card h-100 shadow-sm inspiration-card">
                    @if (!string.IsNullOrEmpty(session.ImageUrl))
                    {
                        <img src="@session.ImageUrl" class="card-img-top session-card-img" alt="@session.Name" />
                    }
                    else if (!string.IsNullOrEmpty(Model.DefaultSessionImageUrl))
                    {
                        <img src="@Model.DefaultSessionImageUrl" class="card-img-top session-card-img" alt="Standardbild" />
                    }
                    else
                    {
                        <div class="session-card-placeholder">
                            <i class="bi bi-image text-muted"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@session.Name</h5>
                        <p class="card-text text-muted flex-grow-1">@session.Description</p>
                        @if (session.DifficultyIds.Any())
                        {
                            <div class="mt-2">
                                @foreach (var diffId in session.DifficultyIds)
                                {
                                    var diffName = Model.Difficulties.FirstOrDefault(d => d.Id == diffId)?.CategoryName ?? diffId.ToString();
                                    <span class="badge bg-secondary me-1">@diffName</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
