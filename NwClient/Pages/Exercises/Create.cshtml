@page
@model NwClient.Pages.Exercises.CreateModel
@{
    ViewData["Title"] = "Ny —vning";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Tillbaka</a>
    <h1 class="h2 mb-0"><i class="bi bi-plus-circle"></i> Ny —vning</h1>
</div>

@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Namn <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="T.ex. Kðllars—k nivÍ 1" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Beskrivning</label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Beskriv —vningen..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bild</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                        <div class="form-text">Valfri bild f—r —vningen (jpg, png, gif etc.).</div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">SvÍrighetsgrader</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var d in Model.Difficulties)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="SelectedDifficultyIds" value="@d.Id"
                                           id="diff_@d.Id" />
                                    <label class="form-check-label" for="diff_@d.Id">@d.CategoryName</label>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Skapa —vning
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Avbryt</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
