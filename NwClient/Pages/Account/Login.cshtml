@page
@model NwClient.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Logga in";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Logga in</h2>

                @if (Model.ErrorMessage != null)
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">E-post</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">L—senord</label>
                        <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary">Logga in</button>
                    </div>
                </form>

                <hr />
                <p class="text-center mb-0">
                    Inget konto? <a asp-page="/Account/Register">Registrera dig</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
